node_modules/
dist/
dist-ssr/
*.local

# Tauri
src-tauri/target/
src-tauri/gen/
# Sidecar binaries are large — don't commit them; build with build-sidecar.ps1
src-tauri/binaries/

# Backend
backend/__pycache__/
backend/.venv/
backend/temp/
backend/dist/
backend/build/
backend/*.spec.bak
*.pyc
*.pyo
.env

# Editor
.vscode/
.idea/
*.swp

# Claude Code
.claude/

# Skills CLI (impeccable etc.) — third-party agent code installed locally.
# The skills-lock.json IS committed so installs are deterministic.
.agents/

# Stray nested repo artefact
pdf-tools/

# Security / audit outputs — these may contain paths or dependency details
.security/reports/
security-audit-*.json
security-audit-*.txt

# Test fixture PDFs and scratch test files — never commit real documents
backend/_test_*.pdf
backend/_test_*.py

# SAST tool caches
.semgrep/
.bandit/
bandit-report.*
pip-audit-report.*

